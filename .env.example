# GLPI szerver - környezeti változók sablon
# Másold: cp .env.example .env
# Töltsd ki az értékeket, soha ne commitold a .env fájlt!

# --- Adatbázis ---
MARIADB_HOST=mysql-arm64
MARIADB_PORT=3306
MARIADB_DATABASE=glpi
MARIADB_USER=
MARIADB_PASSWORD=

# --- Docker ---
GLPI_CONTAINER_NAME=glpi
GLPI_PORT=82
WP_NETWORK=wp_network

# --- Szerver útvonalak ---
GLPI_DATA_PATH=/datas/glpi_data
GLPI_LOG_PATH=/datas/glpi_log
GLPI_BACKUP_PATH=/datas/glpi_backups

# --- Időzóna ---
TIMEZONE=Europe/Budapest
